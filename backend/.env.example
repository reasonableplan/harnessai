# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/agent_db

# GitHub
GITHUB_TOKEN=ghp_your_token_here
GITHUB_OWNER=your_org_or_user
GITHUB_REPO=your_repo
GITHUB_PROJECT_NUMBER=1

# LLM Backend (choose one)
# Option 1: Anthropic API (default)
ANTHROPIC_API_KEY=sk-ant-your_key_here

# Option 2: Claude CLI (for Claude Max subscribers, no API credits needed)
# USE_CLAUDE_CLI=true

# Option 3: Local / OpenAI-compatible (Ollama, LM Studio, vLLM, OpenRouter)
# USE_LOCAL_MODEL=true
# LOCAL_MODEL_BASE_URL=http://localhost:11434/v1
# LOCAL_MODEL_NAME=llama3.1
# LOCAL_MODEL_API_KEY=optional_for_cloud_services

# Workspace
GIT_WORK_DIR=./workspace

# Dashboard Server
DASHBOARD_PORT=3001
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
# DASHBOARD_AUTH_TOKEN=your_secure_token  # optional, skip for dev

# Logging
LOG_LEVEL=info
